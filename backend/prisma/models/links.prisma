model Link {
  id              String   @id @default(uuid())
  slug            String   @unique
  destinationUrl  String   @map("destination_url")
  clickCount      Int      @default(0) @map("click_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  clicks Click[]

  @@map("links")
}
